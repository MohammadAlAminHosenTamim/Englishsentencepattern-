function playAudio(text) {
  // আগের কোনো অডিও চলতে থাকলে তা থামিয়ে দেবে
  let existingAudio = document.getElementById('googleTTSAudio');
  if (existingAudio) {
    existingAudio.pause();
    existingAudio.remove();
  }

  // টেক্সট পরিষ্কার করা
  let cleanText = encodeURIComponent(text.replace(/\[.*?\]/g, '').replace(/\+/g, '').trim());

  // সরাসরি Google Translate এর অডিও সোর্স ব্যবহার
  let audioUrl = `https://translate.google.com/translate_tts?ie=UTF-8&q=${cleanText}&tl=en-gb&client=tw-ob`;

  let audio = new Audio(audioUrl);
  audio.id = 'googleTTSAudio';
  
  // কণ্ঠ আরও গম্ভীর করার জন্য playbackRate ০.৮ বা ০.৯ রাখতে পারেন
  audio.playbackRate = 0.5; 

  audio.play().catch(error => {
    console.warn("Google TTS blocked, using fallback...");
    // ফেইলব্যাক: যদি গুগল কাজ না করে তবে ব্রাউজারের ডিফল্ট ভয়েস ব্যবহার করবে
    let utter = new SpeechSynthesisUtterance(text);
    utter.lang = 'en-GB';
    window.speechSynthesis.speak(utter);
  });
}



  // --- Rendering & Logic ---
  function renderCards(dataArray, containerId) {
    const container = document.getElementById(containerId);
    container.innerHTML = '';

    dataArray.forEach((item, index) => {
      const cardHTML = `
        <div class="flashcard-wrapper" id="card-${item.n}" onclick="toggleCard(${item.n}, ${index}, '${containerId}')">
          <div class="flashcard">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span class="pattern-num">Pattern #${item.n}</span>
              <button class="audio-btn" onclick="event.stopPropagation(); playAudio('${item.pat.replace(/'/g, "\\'")}')">🔊</button>
            </div>
            <div class="pattern-eng">${item.pat}</div>
            <div class="pattern-ben">🎯 ${item.ben}</div>
            <div class="pattern-pro">🗣️ ${item.pro}</div>
            
            <div class="examples-container" id="examples-${item.n}"></div>
            
            <button class="main-audio-btn audio-btn" onclick="event.stopPropagation(); playAudio('${item.pat.replace(/'/g, "\\'")}')">
              🎙️ Listen to Pattern
            </button>
          </div>
        </div>
      `;
      container.innerHTML += cardHTML;
    });
  }

  function shuffleArray(array) {
    let shuffled = array.slice();
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  // Find dataset based on container ID
  function getDatasetByContainer(containerId) {
    if(containerId.includes('sec-1')) return data1st50;
    if(containerId.includes('sec-2')) return data2nd50;
    if(containerId.includes('sec-3')) return data3rd50;
    if(containerId.includes('sec-4')) return data4th50;
    if(containerId.includes('sec-5')) return data5th50;
    if(containerId.includes('sec-6')) return data6th50;
    return data1st50;
  }

  function toggleCard(id, dataIndex, containerId) {
    const cardWrapper = document.getElementById(`card-${id}`);
    const isActive = cardWrapper.classList.contains('active');
    
    document.querySelectorAll('.flashcard-wrapper').forEach(el => el.classList.remove('active'));

    if (!isActive) {
      cardWrapper.classList.add('active');
      const dataset = getDatasetByContainer(containerId);
      const pool = dataset[dataIndex].pool;
      const randomExamples = shuffleArray(pool).slice(0, 5);
      
      const examplesContainer = document.getElementById(`examples-${id}`);
      examplesContainer.innerHTML = '<div style="color: var(--pink); font-size: 0.8rem; letter-spacing:1px; margin-bottom: 5px; font-weight: bold;">⚡ AI EXAMPLES</div>';
      
      randomExamples.forEach((ex, idx) => {
        examplesContainer.innerHTML += `
          <div class="example-item">
            <span class="example-text">${idx + 1}. ${ex}</span>
            <button class="audio-btn" style="width:24px; height:24px; font-size: 10px;" onclick="event.stopPropagation(); playAudio('${ex.replace(/'/g, "\\'")}')">▶</button>
          </div>
        `;
      });
    }
  }

  // Switch tabs and render content dynamically
  function switchTab(tabId, btn, dataArray) {
    document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
    document.getElementById(tabId).classList.add('active');
    
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const gridId = `grid-${tabId}`;
    const phId = `ph-${tabId}`;

    if (dataArray && dataArray.length > 0) {
      document.getElementById(gridId).style.display = "grid";
      if(document.getElementById(phId)) document.getElementById(phId).style.display = "none";
      
      // Render only if empty to save resources
      if(document.getElementById(gridId).innerHTML.trim() === '') {
        renderCards(dataArray, gridId);
      }
    } else {
      document.getElementById(gridId).style.display = "none";
      if(document.getElementById(phId)) document.getElementById(phId).style.display = "block";
    }
  }

